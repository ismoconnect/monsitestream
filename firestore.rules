rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FONCTIONS HELPER ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- REGLES PAR COLLECTION ---

    // 10. STREAMING
    match /streams/{streamId} {
      allow read: if true; 
      allow write: if request.auth != null;
      
      match /offerCandidates/{candidateId} {
        allow read, write: if true;
      }
      match /answerCandidates/{candidateId} {
        allow read, write: if true;
      }
    }

    // 1. PLANS
    match /plans/{planId} {
      allow read, write: if true;
    }

    // 2. UTILISATEURS
    match /users/{userId} {
      allow list: if isAdmin();
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
      
      match /{collectionName}/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // CHAT & MESSAGES
    match /conversations/{conversationId} {
      allow read, write: if isAuthenticated();
    }

    match /messages/{messageId} {
      allow read, write: if isAuthenticated();
    }

    // 4. GALERIE
    match /gallery/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. PAIEMENTS
    match /payments/{paymentId} {
      allow read, write: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
    }

    // 6. LOGS ADMIN
    match /admin_logs/{logId} {
      allow read, write: if isAdmin();
    }
    
    // 7. PRESENCE ET TYPING
    match /presence/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || userId == 'admin' || isAdmin();
    }
    
    match /typing/{docId} {
      allow read, write: if isAuthenticated();
    }

    // 8. CARTES CADEAUX
    match /gift_cards/{cardId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 9. CADEAUX
    match /gifts/{giftId} {
      allow create, read: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // 11. COLLECTION GROUPS (Pour les vues globales Admin)
    match /{path=**}/appointments/{appointmentId} {
      allow read: if isAdmin();
    }
    
    match /{path=**}/notifications/{notificationId} {
      allow read: if isAdmin();
    }
  }
}
